# Database dumps / backups
# =========================
dump/
dumps/
backup/
backups/
*.bson
*.dump
*.archive
*.sqlite
*.sqlite3

# =========================
# Runtime uploads and generated documents
# =========================
uploads/
server/uploads/
storage/
output/
HR Management System Requirements.pdf

# =========================
# Build output
# =========================
**/build/
**/dist/

# =========================
