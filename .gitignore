# Environment files / secrets
# Keep sanitized examples only.
# =========================
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore

# Generated credentials and seed output
**/seed-data/
**/seed-output/
**/*seed-credentials*
**/*demo-credentials*
**/*credentials*.json
**/*credentials*.csv
**/*credentials*.txt
**/scripts/*.local.js

