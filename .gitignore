```gitignore
# =========================
# Dependencies
# =========================
client/node_modules/
server/node_modules/

# =========================
# Environment Files
# =========================
client/.env
client/.env.local
client/.env.development.local
client/.env.test.local
client/.env.production.local

server/.env
server/.env.local
server/.env.development.local
server/.env.test.local
server/.env.production.local

# =========================
# Build Output
# =========================
client/build/
client/dist/
server/build/
server/dist/

# =========================
# Logs
# =========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Cache
# =========================
client/.cache/
client/.parcel-cache/
client/.vite/
server/.cache/

# =========================
# Coverage
# =========================
coverage/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# IDE Files
# =========================
.vscode/
.idea/

# =========================
# Runtime Files
# =========================
*.pid
*.seed
*.pid.lock

# =========================
# Temporary Files
# =========================
tmp/
temp/
```
