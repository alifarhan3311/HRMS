NODE_ENV=development
PORT=5000

MONGO_URI=mongodb://127.0.0.1:27017/hrms
REDIS_URL=redis://127.0.0.1:6379
REDIS_RATE_LIMIT_ENABLED=false

JWT_ACCESS_SECRET=replace_with_64_char_hex_secret
JWT_REFRESH_SECRET=replace_with_64_char_hex_secret
ENCRYPTION_MASTER_KEY=replace_with_64_char_hex_key_32_bytes

CORS_ALLOWED_ORIGINS=http://localhost:5173

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HRMS <no-reply@yourcompany.com>"
