NODE_ENV=development
TRUST_PROXY_HOPS=1
PORT=5000

MONGO_URI=mongodb://127.0.0.1:27017/hrms
# Vercel MongoDB Atlas integration may provide MONGODB_URI instead.
# MONGODB_URI=
REDIS_URL=redis://127.0.0.1:6379
REDIS_RATE_LIMIT_ENABLED=false
AUTH_RATE_LIMIT_MAX=50
API_RATE_LIMIT_MAX=1200
HR_AUTOMATION_ENABLED=true
HR_AUTOMATION_INTERVAL_MS=21600000
ATTENDANCE_RECONCILIATION_DAYS=7
DB_SYNC_INDEXES=true

JWT_ACCESS_SECRET=replace_with_64_char_hex_secret
JWT_REFRESH_SECRET=replace_with_64_char_hex_secret
JWT_ACCESS_EXPIRES_IN=1h
ACCESS_TOKEN_COOKIE_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=30
ENCRYPTION_MASTER_KEY=replace_with_64_char_hex_key_32_bytes

CORS_ALLOWED_ORIGINS=http://localhost:5173
SOCKET_PATH=/socket.io
COOKIE_SAME_SITE=strict

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HRMS <no-reply@yourcompany.com>"

# One-time first-account bootstrap (remove after successful use)
BOOTSTRAP_SUPER_ADMIN_EMAIL=
BOOTSTRAP_SUPER_ADMIN_PASSWORD=
BOOTSTRAP_SUPER_ADMIN_NAME=Super Admin
BOOTSTRAP_COMPANY_ID=667788990011223344556677
