# Vercel proxies these same-origin paths to the backend configured in
# client/vercel.json. This keeps HttpOnly auth cookies first-party.
VITE_API_BASE_URL=/api/v1
VITE_SOCKET_URL=https://app.example.com
# Keep false while the backend runs as a Vercel function. Set true only
# when Socket.IO is deployed on a long-running Node host.
VITE_REALTIME_ENABLED=false
